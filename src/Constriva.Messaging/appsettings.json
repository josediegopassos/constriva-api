{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "MassTransit": "Information",
        "MongoDB": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/messaging-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "RabbitMq": {
    "Host": "localhost",
    "Porta": 5672,
    "Usuario": "constriva",
    "Senha": "constriva",
    "VirtualHost": "/",
    "PrefetchCount": 10,
    "LimiteConcorrencia": 5
  },
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "NomeBanco": "constriva_lens_logs",
    "NomeColecaoLogs": "log_processamento_lens",
    "TtlDiasRetencao": 90
  },
  "ConstrivaLens": {
    "BaseUrl": "http://localhost:8001",
    "ClientId": "constriva-api",
    "ClientSecret": "constriva-secret-change-in-prod",
    "TimeoutSegundos": 120
  },
  "ConstrivaApi": {
    "BaseUrl": "http://localhost:5000",
    "ChaveInterna": "chave-interna-compartilhada"
  }
}
